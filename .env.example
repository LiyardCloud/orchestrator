# =============================================================================
# General
# =============================================================================

POSTGRES_USER=
POSTGRES_PASSWORD=


# =============================================================================
# Gateway
# =============================================================================

# Firebase service account (individual fields — used by the Go gateway)
# Download: Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Shared secret for internal service-to-service calls
SERVICE_KEY=


# =============================================================================
# Dataroom — Backend (Go)
# =============================================================================

# Token encryption — reuse existing value if migrating from Flask
FERNET_KEY=

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api-dataroom.liyard.cloud/oauth/google-drive/callback

# Frontend origin (used by Go service for CORS)
FRONTEND_URL=https://dataroom.liyard.cloud


# =============================================================================
# Dataroom — Frontend
# =============================================================================

# Firebase (Firebase Console → Project settings → Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google Drive Picker (Google Cloud Console → APIs & Services → Credentials)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
